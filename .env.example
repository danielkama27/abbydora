# ============================================
# ABBYDORA Environment Configuration
# ============================================

# Database (SQLite)
# For local dev: file path relative to prisma/ folder
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# Session & Auth Secret (must be at least 32 chars)
# Used by both NextAuth (v5) and iron-session
AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"
SESSION_SECRET="your-super-secret-key-at-least-32-characters-long"

# NextAuth base URL (optional for local dev, required for production)
AUTH_URL="http://localhost:3000"

# Google OAuth (required for Google sign-in)
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin config (comma-separated emails that get admin role on sign-in)
ADMIN_EMAILS="admin@abbydora.com"

# AWS S3 / S3-compatible storage (for product images, etc.)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="abbydora-assets"
# Optional: custom S3 endpoint (e.g. for MinIO, Cloudflare R2)
# AWS_S3_ENDPOINT="https://s3.amazonaws.com"
