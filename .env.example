# ============================================
# ABBYDORA Environment Configuration
# ============================================

# Database (SQLite)
# For local dev: file path relative to prisma/ folder
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# Session & Auth Secret (must be at least 32 chars)
# Used by both NextAuth (v5) and iron-session
AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"
SESSION_SECRET="your-super-secret-key-at-least-32-characters-long"

# NextAuth base URL (optional for local dev, required for production)
AUTH_URL="http://localhost:3000"

# Google OAuth (required for Google sign-in)
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin config (comma-separated emails that get admin role on sign-in)
ADMIN_EMAILS="admin@abbydora.com"

# Cloudinary (for product image uploads)
# Get these from your Cloudinary dashboard at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend (for password reset emails)
# Get a free API key at https://resend.com (no card required)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="AbbyDora <onboarding@resend.dev>"

# M-Pesa (Safaricom Daraja API — for customer M-Pesa payments)
# Get these from https://developer.safaricom.co.ke after creating an app
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="your-passkey"
MPESA_CALLBACK_URL="https://your-app-address.onrender.com/api/mpesa/callback"
